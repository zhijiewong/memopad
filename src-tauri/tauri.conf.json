{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memopad",
  "version": "0.2.0",
  "identifier": "dev.memopad.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memopad",
        "label": "main",
        "width": 1100,
        "height": 720,
        "minWidth": 480,
        "minHeight": 320,
        "decorations": false,
        "resizable": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/zhijiewong/memopad/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFRjEyNEQ1RjJEMzQ1MwpSV1JUTkMxZlRSTHZBa3RXaDhCaStDVkxrQVQ2WUxYYXFYOWxENXZYT2hQUDFoUlNCUEJMam9CcAo=",
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
